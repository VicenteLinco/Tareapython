# Copy this file to .env for local development. Never commit real values.

# Local PostgreSQL / Compose
POSTGRES_DB=inventario_lab_dev
POSTGRES_USER=CHANGE_ME_LOCAL_USER
POSTGRES_PASSWORD=CHANGE_ME_LOCAL_PASSWORD
DATABASE_URL=postgresql://CHANGE_ME_LOCAL_USER:CHANGE_ME_LOCAL_PASSWORD@127.0.0.1:5432/inventario_lab_dev

# Required application secrets (use distinct values, each at least 32 characters)
JWT_SECRET=CHANGE_ME_GENERATE_A_DISTINCT_32_CHAR_SECRET
JWT_REFRESH_SECRET=CHANGE_ME_GENERATE_ANOTHER_32_CHAR_SECRET
JWT_ACCESS_EXPIRATION=900
JWT_REFRESH_EXPIRATION=86400

# HTTP and logging
PORT=8080
CORS_ORIGIN=http://localhost:5072
RUST_LOG=info
ENABLE_SWAGGER=false
LOGIN_RATE_LIMIT_PER_MINUTE=10
MUTATION_RATE_LIMIT_PER_MINUTE=120
READ_RATE_LIMIT_PER_MINUTE=600

# Initial administration (disabled by default)
ALLOW_BOOTSTRAP_ADMIN=false
# SETUP_ADMIN_EMAIL=admin@example.invalid
# SETUP_ADMIN_PASSWORD=CHANGE_ME_TEMPORARY_ADMIN_PASSWORD

# Optional integrations. Replace every placeholder only when the integration is enabled.
TWILIO_AUTH_TOKEN=CHANGE_ME_IF_TWILIO_IS_ENABLED
WHATSAPP_WEBHOOK_SECRET=CHANGE_ME_IF_WHATSAPP_IS_ENABLED
WHATSAPP_API_URL=http://127.0.0.1:8008
WHATSAPP_API_KEY=CHANGE_ME_IF_WHATSAPP_IS_ENABLED
