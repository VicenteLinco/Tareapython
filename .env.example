# =============================================================================
# Variables de entorno para Docker Compose
# Copia este archivo a .env y completa los valores reales antes de desplegar
# =============================================================================

# PostgreSQL
POSTGRES_DB=inventario_lab
POSTGRES_USER=lab_user
POSTGRES_PASSWORD=CHANGE_ME_password_seguro_aqui

# JWT (mínimo 32 caracteres aleatorios — genera uno con: openssl rand -hex 32)
JWT_SECRET=CHANGE_ME_minimo_32_caracteres_clave_secreta_aqui

# Logging (debug | info | warn | error)
RUST_LOG=info

# Bootstrap admin inicial
# Mantener false salvo durante el setup inicial. Si se habilita, ambas variables son obligatorias.
ALLOW_BOOTSTRAP_ADMIN=false
# SETUP_ADMIN_EMAIL=admin@laboratorio.cl
# SETUP_ADMIN_PASSWORD=CHANGE_ME_password_admin_temporal
