# Generated build and dependency state
/build/*
!/build/.gitignore
/source/backend/target/
/source/frontend/node_modules/
/source/frontend/dist/
/source/frontend/.vite/
/source/frontend/coverage/
*.log

# Secrets and local credentials
.env
.env.*
!.env.example
**/.env
**/.env.*
!**/.env.example
**/*.key
**/*.pem
**/credentials.json
**/secrets/
**/.credentials/
**/.aws/credentials
**/.ssh/

# Runtime and local data
/uploads/
*.dump
*.bak

# Checkout-local tooling and editor state
/.codegraph/
/.atl/
AGENTS.md
CLAUDE.md
.DS_Store
.idea/
.vscode/
