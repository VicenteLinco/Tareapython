# Base de datos
DATABASE_URL=postgres://lab_user:lab_password@localhost:5432/inventario_lab

# JWT
JWT_SECRET=cambiar-en-produccion-con-valor-seguro-de-al-menos-32-caracteres
JWT_ACCESS_EXPIRATION=900
JWT_REFRESH_EXPIRATION=86400

# Server
PORT=8080
RUST_LOG=info

# CORS (usar * para desarrollo, dominio específico en producción)
CORS_ORIGIN=http://localhost:5173

# Produccion: mantener Swagger apagado y ajustar rate limits desde Render si hace falta.
ENABLE_SWAGGER=false
LOGIN_RATE_LIMIT_PER_MINUTE=10
MUTATION_RATE_LIMIT_PER_MINUTE=120
READ_RATE_LIMIT_PER_MINUTE=600
